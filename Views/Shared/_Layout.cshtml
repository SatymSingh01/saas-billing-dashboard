<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SaaS Billing</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background: #1e2a3a; color: #cfd8e3; }
        .sidebar .nav-link { color: #cfd8e3; padding: .6rem 1.25rem; border-radius: .375rem; margin: 2px 0; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: #2d3f55; color: #fff; }
        .sidebar .brand { font-size: 1.2rem; font-weight: 700; color: #fff; padding: 1.25rem; }
        .stat-card { border: none; border-radius: .75rem; box-shadow: 0 1px 6px rgba(0,0,0,.08); }
        .badge-paid { background-color: #198754; }
        .badge-sent { background-color: #0dcaf0; color: #000; }
        .badge-overdue { background-color: #dc3545; }
        .badge-draft { background-color: #6c757d; }
        .badge-cancelled { background-color: #adb5bd; color: #000; }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2 d-md-block sidebar py-3 px-2">
            <div class="brand"><i class="bi bi-credit-card-2-front me-2"></i>Billing</div>
            <ul class="nav flex-column mt-2">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")"
                       asp-controller="Customers" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Customers
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Subscriptions" ? "active" : "")"
                       asp-controller="Subscriptions" asp-action="Index">
                        <i class="bi bi-arrow-repeat me-2"></i>Subscriptions
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" ? "active" : "")"
                       asp-controller="Invoices" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Invoices
                    </a>
                </li>
                <hr style="border-color: #2d3f55;" />
                <li class="nav-item">
                    <a class="nav-link" href="/api/payments/summary" target="_blank">
                        <i class="bi bi-braces me-2"></i>REST API
                    </a>
                </li>
            </ul>
            <div class="mt-4 px-3 small text-muted">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-person-circle"></i>
                        <span class="text-truncate">@User.Identity.Name</span>
                    </div>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Sign out</button>
                    </form>
                }
            </div>
        </nav>

        <main class="col-md-10 ms-sm-auto px-4 py-4">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
