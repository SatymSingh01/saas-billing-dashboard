@model Invoice
@{ ViewData["Title"] = "New Invoice"; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="text-muted"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-semibold mb-0">New Invoice</h4>
</div>

<div class="card stat-card" style="max-width:540px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="CustomerId" class="form-label">Customer</label>
                <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select">
                    <option value="">— Select customer —</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label">Subtotal</label>
                <input asp-for="Amount" type="number" step="0.01" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="TaxAmount" class="form-label">Tax</label>
                <input asp-for="TaxAmount" type="number" step="0.01" class="form-control" value="0" />
            </div>
            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" type="date" class="form-control" value="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" />
            </div>
            <div class="mb-4">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Create Invoice</button>
            <a asp-action="Index" class="btn btn-link">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
