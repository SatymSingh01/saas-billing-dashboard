@model Invoice
@{ ViewData["Title"] = Model.InvoiceNumber; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="text-muted"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-semibold mb-0">@Model.InvoiceNumber</h4>
    <span class="badge badge-@Model.Status.ToString().ToLower() fs-6">@Model.Status</span>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager") && Model.Status != InvoiceStatus.Paid)
    {
        <div class="ms-2 d-flex gap-2">
            @if (Model.Status == InvoiceStatus.Draft)
            {
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="status" value="Sent" />
                    <button type="submit" class="btn btn-sm btn-outline-info">Mark Sent</button>
                </form>
            }
            @if (Model.Status == InvoiceStatus.Sent || Model.Status == InvoiceStatus.Overdue)
            {
                <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#payModal">
                    <i class="bi bi-check-circle me-1"></i>Record Payment
                </button>
            }
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card stat-card p-3 mb-3">
            <div class="text-muted small mb-1">Bill To</div>
            <div class="fw-semibold">@Model.Customer.Name</div>
            <div>@Model.Customer.Email</div>
            @if (Model.Customer.Company != null) { <div class="text-muted">@Model.Customer.Company</div> }
        </div>

        <div class="card stat-card p-3">
            <div class="row text-center">
                <div class="col">
                    <div class="text-muted small">Subtotal</div>
                    <div class="fw-semibold">@Model.Amount.ToString("C")</div>
                </div>
                <div class="col">
                    <div class="text-muted small">Tax</div>
                    <div class="fw-semibold">@Model.TaxAmount.ToString("C")</div>
                </div>
                <div class="col">
                    <div class="text-muted small">Total</div>
                    <div class="fw-bold fs-5">@((Model.Amount + Model.TaxAmount).ToString("C"))</div>
                </div>
            </div>
            <hr />
            <div class="d-flex justify-content-between small text-muted">
                <span>Issued: @Model.IssuedDate.ToString("MMM d, yyyy")</span>
                <span>Due: @Model.DueDate.ToString("MMM d, yyyy")</span>
            </div>
            @if (Model.Notes != null)
            {
                <div class="mt-2 text-muted small">@Model.Notes</div>
            }
        </div>
    </div>

    <div class="col-md-7">
        <div class="card stat-card">
            <div class="card-header bg-white fw-semibold">Payment History</div>
            <div class="card-body p-0">
                @if (!Model.Payments.Any())
                {
                    <p class="p-3 text-muted mb-0">No payments recorded.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Date</th><th>Amount</th><th>Method</th><th>Transaction ID</th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.Payments.OrderByDescending(x => x.PaidAt))
                            {
                                <tr>
                                    <td>@p.PaidAt.ToString("MMM d, yyyy")</td>
                                    <td>@p.Amount.ToString("C")</td>
                                    <td>@p.Method</td>
                                    <td><code>@(p.TransactionId ?? "—")</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Manager"))
{
    <div class="modal fade" id="payModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="RecordPayment" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Record Payment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="invoiceId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Amount</label>
                            <input name="amount" type="number" step="0.01" class="form-control"
                                   value="@((Model.Amount + Model.TaxAmount).ToString("F2"))" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payment Method</label>
                            <select name="method" class="form-select">
                                @foreach (var m in Enum.GetValues<PaymentMethod>())
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Transaction ID (optional)</label>
                            <input name="transactionId" class="form-control" placeholder="TXN-…" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
