@model IEnumerable<Invoice>
@{ ViewData["Title"] = "Invoices"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-semibold mb-0">Invoices</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New Invoice</a>
    }
</div>

<div class="card stat-card mb-3">
    <div class="card-body py-2">
        <div class="d-flex gap-2 flex-wrap">
            @foreach (var s in new[] { "", "Draft", "Sent", "Paid", "Overdue", "Cancelled" })
            {
                <a asp-action="Index" asp-route-status="@s"
                   class="btn btn-sm @(ViewBag.StatusFilter as string == s ? "btn-primary" : "btn-outline-secondary")">
                    @(string.IsNullOrEmpty(s) ? "All" : s)
                </a>
            }
        </div>
    </div>
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Invoice #</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Issued</th>
                    <th>Due</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@inv.Id"><code>@inv.InvoiceNumber</code></a></td>
                        <td>@inv.Customer.Name</td>
                        <td>@((inv.Amount + inv.TaxAmount).ToString("C"))</td>
                        <td>@inv.IssuedDate.ToString("MMM d, yyyy")</td>
                        <td class="@(inv.Status == InvoiceStatus.Overdue ? "text-danger fw-semibold" : "")">
                            @inv.DueDate.ToString("MMM d, yyyy")
                        </td>
                        <td><span class="badge badge-@inv.Status.ToString().ToLower()">@inv.Status</span></td>
                        <td><a asp-action="Details" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-secondary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
