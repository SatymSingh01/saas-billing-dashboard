@model IEnumerable<Customer>
@{ ViewData["Title"] = "Customers"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-semibold mb-0">Customers</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New Customer</a>
    }
</div>

<div class="card stat-card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input name="search" value="@ViewBag.Search" class="form-control form-control-sm w-auto" placeholder="Search name, email, company…" />
            <button type="submit" class="btn btn-sm btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-sm btn-link">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Company</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@c.Id">@c.Name</a></td>
                        <td>@c.Email</td>
                        <td>@(c.Company ?? "—")</td>
                        <td>
                            <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">
                                @(c.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>@c.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
