@model Customer
@{ ViewData["Title"] = Model.Name; }

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="text-muted"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-semibold mb-0">@Model.Name</h4>
    <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary ms-2">Edit</a>
    }
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Contact</div>
            <div>@Model.Email</div>
            @if (Model.Phone != null) { <div class="text-muted">@Model.Phone</div> }
            @if (Model.Company != null) { <div>@Model.Company</div> }
            <div class="text-muted small mt-2">Customer since @Model.CreatedAt.ToString("MMM d, yyyy")</div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card stat-card mb-3">
            <div class="card-header bg-white fw-semibold">Subscriptions</div>
            <div class="card-body p-0">
                @if (!Model.Subscriptions.Any())
                {
                    <p class="p-3 text-muted mb-0">No subscriptions.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Plan</th><th>Started</th><th>Next Billing</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.Subscriptions)
                            {
                                <tr>
                                    <td>@s.Plan?.Name</td>
                                    <td>@s.StartDate.ToString("MMM d, yyyy")</td>
                                    <td>@(s.NextBillingDate?.ToString("MMM d, yyyy") ?? "—")</td>
                                    <td><span class="badge bg-@(s.Status == SubscriptionStatus.Active ? "success" : "secondary")">@s.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card stat-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Invoices</span>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a asp-controller="Invoices" asp-action="Create" class="btn btn-sm btn-outline-primary">New Invoice</a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.Invoices.Any())
                {
                    <p class="p-3 text-muted mb-0">No invoices.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Invoice #</th><th>Amount</th><th>Due</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var inv in Model.Invoices.OrderByDescending(i => i.IssuedDate))
                            {
                                <tr>
                                    <td><a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.Id"><code>@inv.InvoiceNumber</code></a></td>
                                    <td>@((inv.Amount + inv.TaxAmount).ToString("C"))</td>
                                    <td>@inv.DueDate.ToString("MMM d, yyyy")</td>
                                    <td><span class="badge badge-@inv.Status.ToString().ToLower()">@inv.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
